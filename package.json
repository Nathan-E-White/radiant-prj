{
  "name": "kaleidos-compute-readiness-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Interview-facing Kaleidos compute readiness console with synthetic transport jobs, evidence traceability, and dry-run DevOps artifacts.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "PATH=/opt/homebrew/bin:/usr/local/bin:$PATH vitest run",
    "test:e2e": "playwright test",
    "fleet-board:prototype": "bun scripts/fleet-board-prototype.ts",
    "fleet-board:v2-assets:check": "node scripts/check-fleet-board-v2-assets.mjs",
    "validate:fixtures": "node scripts/validate-fixtures.mjs",
    "evidence:generate": "node scripts/generate-evidence.mjs",
    "infra:check": "node scripts/check-infra.mjs",
    "compose:smoke": "scripts/compose-smoke.sh",
    "quality:check": "node scripts/check-quality-docs.mjs",
    "adr:check": "node scripts/check-adr-docs.mjs",
    "simops:contract:check": "node scripts/check-simops-contract.mjs",
    "simops:generator:test": "CARGO_TARGET_DIR=\"${CARGO_TARGET_DIR:-/tmp/radiant-cargo-target/simops-generator}\" cargo test --manifest-path workers/simops-generator/Cargo.toml",
    "simops:smoke:json:test": "node --test scripts/simops-smoke-json.node-test.mjs",
    "simulator-workbench:contract:check": "node scripts/check-simulator-workbench-contract.mjs",
    "scada:standins:test": "CARGO_TARGET_DIR=\"${CARGO_TARGET_DIR:-/tmp/radiant-cargo-target/scada-standins}\" cargo test --manifest-path workers/scada-standins/Cargo.toml",
    "simops:smoke:local": "scripts/simops-local-smoke.sh",
    "simops:smoke:docker-orbstack": "scripts/simops-docker-orbstack-smoke.sh",
    "simops:smoke:kind": "scripts/simops-kind-smoke.sh",
    "simops:smoke:kind:check": "node scripts/check-simops-kind-smoke.mjs",
    "simops:tofu:check": "node scripts/check-simops-opentofu-substrate.mjs",
    "simops:tofu:preflight": "scripts/simops-opentofu-preflight.sh",
    "simops:runtime:closeout:check": "node scripts/check-simops-runtime-closeout.mjs",
    "simulator-workbench:dataflow:smoke": "scripts/simulator-workbench-dataflow-smoke.sh",
    "storybook": "storybook dev --no-open --port 6006",
    "build-storybook": "storybook build",
    "backend:test": "cd backend/slurm-gateway && PATH=/opt/homebrew/bin:/usr/local/bin:$PATH env GOCACHE=/tmp/radiant-go-cache GOMODCACHE=/tmp/radiant-go-mod-cache go test ./...",
    "backend:snapshot:postgres:test": "cd backend/slurm-gateway && PATH=/opt/homebrew/bin:/usr/local/bin:$PATH env GOCACHE=/tmp/radiant-go-cache GOMODCACHE=/tmp/radiant-go-mod-cache go test -tags postgresintegration ./internal/gateway -run '^TestPostgres.*Snapshot|^TestPostgresTwinTransition' -count=1",
    "backend:deps:check": "node scripts/check-go-gateway-deps.mjs",
    "backend:run": "cd backend/slurm-gateway && go run ./cmd/server",
    "certs:local": "scripts/create-local-gateway-certs.sh",
    "docker:up": "scripts/docker-up.sh",
    "docker:down": "scripts/docker-down.sh",
    "docker:prune:plan": "scripts/docker-prune-hygiene.sh --all",
    "docker:prune:check": "node scripts/check-docker-prune-hygiene.mjs",
    "docker:storage:check": "node scripts/check-docker-storage-policy.mjs",
    "hygiene:size": "node scripts/hygiene-size.mjs",
    "hygiene:size:check": "node scripts/check-hygiene-size.mjs",
    "hygiene:clean": "node scripts/hygiene-clean.mjs",
    "hygiene:clean:check": "node scripts/check-hygiene-clean.mjs",
    "mock:worker": "node scripts/mock-worker.mjs",
    "checkpoint:wip": "scripts/checkpoint-wip.sh",
    "fold:branch": "scripts/fold-branch.sh",
    "checkpoint:version": "scripts/checkpoint-version.sh",
    "cleanup:version": "scripts/cleanup-version-hygiene.sh",
    "fold:v2": "scripts/archive/fold-v2-to-main.sh",
    "checkpoint:v2": "scripts/archive/checkpoint-v2.sh",
    "cleanup:v2": "scripts/archive/cleanup-v2-hygiene.sh",
    "ci": "\"$npm_execpath\" run typecheck && \"$npm_execpath\" run test && \"$npm_execpath\" run fleet-board:v2-assets:check && \"$npm_execpath\" run backend:test && \"$npm_execpath\" run backend:deps:check && \"$npm_execpath\" run validate:fixtures && \"$npm_execpath\" run evidence:generate && \"$npm_execpath\" run infra:check && \"$npm_execpath\" run quality:check && \"$npm_execpath\" run adr:check && \"$npm_execpath\" run simops:contract:check && \"$npm_execpath\" run simulator-workbench:contract:check && \"$npm_execpath\" run docker:prune:check && \"$npm_execpath\" run docker:storage:check && \"$npm_execpath\" run hygiene:size:check && \"$npm_execpath\" run hygiene:clean:check && \"$npm_execpath\" run simops:smoke:json:test && \"$npm_execpath\" run simops:smoke:kind:check && \"$npm_execpath\" run simops:tofu:check && \"$npm_execpath\" run simops:runtime:closeout:check && \"$npm_execpath\" run simops:generator:test && \"$npm_execpath\" run scada:standins:test",
    "ci:full": "\"$npm_execpath\" run ci && \"$npm_execpath\" run compose:smoke"
  },
  "dependencies": {
    "@storybook/react-vite": "^10.4.6",
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.468.0",
    "phaser": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.3",
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
