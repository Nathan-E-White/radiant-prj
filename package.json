{
  "name": "kaleidos-compute-readiness-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Interview-facing Kaleidos compute readiness console with synthetic transport jobs, evidence traceability, and dry-run DevOps artifacts.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "validate:fixtures": "node scripts/validate-fixtures.mjs",
    "evidence:generate": "node scripts/generate-evidence.mjs",
    "infra:check": "node scripts/check-infra.mjs",
    "compose:smoke": "scripts/compose-smoke.sh",
    "quality:check": "node scripts/check-quality-docs.mjs",
    "adr:check": "node scripts/check-adr-docs.mjs",
    "simops:contract:check": "node scripts/check-simops-contract.mjs",
    "simops:generator:test": "cd workers/simops-generator && cargo test",
    "backend:test": "cd backend/slurm-gateway && env GOCACHE=/tmp/radiant-go-cache go test ./...",
    "backend:run": "cd backend/slurm-gateway && go run ./cmd/server",
    "certs:local": "scripts/create-local-gateway-certs.sh",
    "docker:up": "scripts/docker-up.sh",
    "docker:down": "scripts/docker-down.sh",
    "mock:worker": "node scripts/mock-worker.mjs",
    "checkpoint:wip": "scripts/checkpoint-wip.sh",
    "fold:branch": "scripts/fold-branch.sh",
    "checkpoint:version": "scripts/checkpoint-version.sh",
    "cleanup:version": "scripts/cleanup-version-hygiene.sh",
    "fold:v2": "scripts/archive/fold-v2-to-main.sh",
    "checkpoint:v2": "scripts/archive/checkpoint-v2.sh",
    "cleanup:v2": "scripts/archive/cleanup-v2-hygiene.sh",
    "ci": "bun run typecheck && bun run test && bun run backend:test && bun run validate:fixtures && bun run evidence:generate && bun run infra:check && bun run quality:check && bun run adr:check && bun run simops:contract:check && bun run simops:generator:test",
    "ci:full": "bun run ci && bun run compose:smoke"
  },
  "dependencies": {
    "@storybook/react-vite": "^10.4.6",
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
