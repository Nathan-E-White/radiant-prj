{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radiant.local/schemas/scada/resident-source-declaration.v1.schema.json",
  "title": "Resident SCADA Stand-In Source Declaration v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sourceId",
    "displayName",
    "lifecycle",
    "syntheticStatus",
    "ingest",
    "tags"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "enum": ["scada.resident-source-declaration.v1"] },
    "sourceId": { "type": "string", "pattern": "^[A-Z0-9][A-Z0-9_-]{2,96}$" },
    "displayName": { "type": "string" },
    "lifecycle": { "type": "string", "enum": ["resident"] },
    "syntheticStatus": { "type": "string", "enum": ["public-safe-standin"] },
    "ingest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["topic", "endpointKind"],
      "properties": {
        "topic": { "type": "string", "enum": ["scada.telemetry.v1"] },
        "endpointKind": { "type": "string", "enum": ["gateway-http"] }
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tagId", "assetId", "signalKind", "unit", "valueBasis"],
        "properties": {
          "tagId": { "type": "string", "pattern": "^[A-Z0-9][A-Z0-9_-]{2,96}$" },
          "assetId": { "type": "string", "pattern": "^[A-Z0-9][A-Z0-9_-]{2,96}$" },
          "signalKind": {
            "type": "string",
            "enum": ["flux", "temperature", "pressure", "flow", "actuatorState", "electricalState", "comms"]
          },
          "unit": { "type": "string" },
          "valueBasis": { "type": "string", "enum": ["measured"] }
        }
      }
    }
  }
}
