{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "payload.checkpoint-storage.v1",
  "title": "Checkpoint Storage Payload v1",
  "type": "object",
  "required": ["parallelFileSystem", "burstBuffer", "nvmeOf", "checkpoint", "storageTargets"],
  "additionalProperties": false,
  "properties": {
    "parallelFileSystem": {
      "type": "object",
      "required": ["readIops", "writeIops", "metadataOps", "health"],
      "additionalProperties": false,
      "properties": {
        "readIops": { "type": "number", "minimum": 0, "maximum": 1000000 },
        "writeIops": { "type": "number", "minimum": 0, "maximum": 1000000 },
        "metadataOps": { "type": "number", "minimum": 0, "maximum": 500000 },
        "health": { "type": "string", "enum": ["nominal", "watch", "degraded"] }
      }
    },
    "burstBuffer": {
      "type": "object",
      "required": ["writeThroughputGbps", "flushThroughputGbps", "queuedGiB"],
      "additionalProperties": false,
      "properties": {
        "writeThroughputGbps": { "type": "number", "minimum": 0, "maximum": 500 },
        "flushThroughputGbps": { "type": "number", "minimum": 0, "maximum": 500 },
        "queuedGiB": { "type": "number", "minimum": 0, "maximum": 100000 }
      }
    },
    "nvmeOf": {
      "type": "object",
      "required": ["cacheSaturationPct", "writeAmp", "targetQueueDepth"],
      "additionalProperties": false,
      "properties": {
        "cacheSaturationPct": { "type": "number", "minimum": 0, "maximum": 100 },
        "writeAmp": { "type": "number", "minimum": 1, "maximum": 20 },
        "targetQueueDepth": { "type": "integer", "minimum": 0, "maximum": 4096 }
      }
    },
    "checkpoint": {
      "type": "object",
      "required": ["checkpointId", "progressPct", "etaSec", "status"],
      "additionalProperties": false,
      "properties": {
        "checkpointId": { "type": "string" },
        "progressPct": { "type": "number", "minimum": 0, "maximum": 100 },
        "etaSec": { "type": "number", "minimum": 0, "maximum": 3600 },
        "status": { "type": "string", "enum": ["not-started", "writing", "flushing", "complete", "stalled"] }
      }
    },
    "storageTargets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["targetId", "role", "degradationPct", "readLatencyMs", "writeLatencyMs", "saturationPct"],
        "additionalProperties": false,
        "properties": {
          "targetId": { "type": "string" },
          "role": { "type": "string", "enum": ["metadata", "object", "burst"] },
          "degradationPct": { "type": "number", "minimum": 0, "maximum": 100 },
          "readLatencyMs": { "type": "number", "minimum": 0, "maximum": 1000 },
          "writeLatencyMs": { "type": "number", "minimum": 0, "maximum": 1000 },
          "saturationPct": { "type": "number", "minimum": 0, "maximum": 100 }
        }
      }
    }
  }
}
